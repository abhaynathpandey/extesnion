{
  "manifest_version": 3,
  "name": "DupCheck Evaluator",
  "version": "1.2.0",
  "description": "Duplicate detection evaluator for WALLE — auto-analyzes GTINs, highlights differences, catches intra-GTIN discrepancies. No API required.",
  "permissions": ["activeTab", "scripting", "tabs"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
